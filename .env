# ==========================================
# 🎯 HABIT TRACKER - Environment Variables
# ==========================================

# ===== MONGODB ATLAS =====
# Connection string до вашого MongoDB cluster
MONGO_URI=mongodb+srv://testuser:Test123456@cluster0.ubujbz2.mongodb.net/habit-tracker?retryWrites=true&w=majority&authSource=admin
# ===== JWT SECRET =====
# Secret ключ для підписання JWT токенів
JWT_SECRET=secret123

# ===== SERVER PORT =====
# На якому порту запускається Node.js сервер
PORT=5000

# ===== FRONTEND API =====
# Адреса, на яку клієнт звертається до API
VITE_API=http://localhost:5000/api
